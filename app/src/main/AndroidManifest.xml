<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Setting"
        tools:targetApi="31">

        <!-- LoginActivity as the main entry point -->
        <activity
            android:name=".MainScreen"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- SignUpActivity without intent-filter -->
        <activity android:name=".SignupActivity" />

        <!-- login Activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="true" />

        <!-- ScreenKeduaActivity -->
        <activity
            android:name=".ScreenKeduaActivity"
            android:exported="true" />

        <!-- ScreenKetigaActivity -->
        <activity
            android:name=".ScreenKetigaActivity"
            android:exported="true" />

        <!-- ScreenKeempatActivity -->
        <activity android:name=".ScreenKeempatActivity" />

        <!-- ScreenKelimaActivity -->
        <activity android:name=".ScreenKelimaActivity" />

        <!-- ScreenKeenamActivity -->
        <activity android:name=".ScreenKeenamActivity" />

        <!-- ScreenKetujuhActivity -->
        <activity android:name=".ScreenKetujuhActivity" />

        <!-- Friend Activity -->
        <activity android:name=".friendActivity" />

        <!-- Additional Activities from Community App -->
        <activity
            android:name=".Community"
            android:exported="false" />
            
        <activity
            android:name=".ShopActivity"
            android:exported="false" />
            
        <activity
            android:name=".EditPass"
            android:exported="false" />
            
        <activity
            android:name=".EditProfile"
            android:exported="false" />
        
        <!-- Daily Task Activity -->
        <activity
            android:name=".DailyTaskActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Challenge Activity -->
        <activity
            android:name="com.example.setting.ChallengeActivity" />
        
        <!-- Add Challenge Activity -->
        <activity
            android:name="com.example.setting.AddChallengeActivity" />

        <activity android:name=".GoalsHubActivity" />


    </application>
</manifest>
